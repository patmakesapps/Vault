{
  "name": "vault-app",
  "version": "1.0.0",
  "description": "Your personal encrypted secrets vault",
  "author": "Lumalien",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:ui": "vite build",
    "build": "npm run build:ui && electron-builder --publish never",
    "build:win": "npm run build:ui && electron-builder --win nsis portable --publish never",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.lumalien.vault",
    "productName": "Vault",
    "icon": "src/assets/icon.ico",
    "directories": {
      "output": "dist-electron"
    },
    "artifactName": "${productName}-${version}-win-${arch}-setup.${ext}",
    "asar": true,
    "compression": "maximum",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "src/assets/icon.ico",
      "signAndEditExecutable": true,
      "publisherName": "Lumalien"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-win-${arch}-setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "installerIcon": "src/assets/icon.ico",
      "uninstallerIcon": "src/assets/icon.ico",
      "installerHeaderIcon": "src/assets/icon.ico"
    },
    "portable": {
      "artifactName": "${productName}-${version}-win-${arch}-portable.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/icon.png"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "src/assets/icon.png",
      "src/assets/icon.ico"
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.0",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
